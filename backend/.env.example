# Пример настроек для бэкенда FastAPI
# Скопируйте этот файл при необходимости и поменяйте значения

# Секрет для подписания JWT (в реальном проекте используйте длинную случайную строку)
JWT_SECRET="change_me_super_secret_key"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=60

# Данные первоначального администратора (создаётся в памяти при старте)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin12345"

# CORS (допустимое origin фронтенда)
FRONTEND_ORIGIN="http://127.0.0.1:5173"

# SMTP для отправки писем о заявках
# Пример для Яндекс.Почты:
# SMTP_HOST="smtp.yandex.ru"
# SMTP_PORT=587
# SMTP_USER="your_login@yandex.ru"
# SMTP_PASSWORD="your_app_password"
# SMTP_FROM="your_login@yandex.ru"

# Куда отправлять все новые заявки
NOTIFICATIONS_EMAIL="nikiforov-kslksl@yandex.ru"
